{
  "name": "Soft Pastel Aqua Light",
  "colors": {
    "foreground": "#334248",
    "editor.background": "#EAF3F7",
    "editor.foreground": "#334248",
    "editor.selectionBackground": "#cee2eb",
    "editorCursor.foreground": "#91abb6",
    "editorLineNumber.foreground": "#808c92",
    "editorLineNumber.activeForeground": "#93aeba",
    "editorIndentGuide.background1": "#d0dadf",
    "editorIndentGuide.activeBackground1": "#7c949f",
    "editorWhitespace.foreground": "#d4dee2",
    "editorInlayHint.foreground": "#80939b",
    "editorInlayHint.background": "#e4eff4",
    "sideBar.foreground": "#334248",
    "sideBar.background": "#e2eef3",
    "sideBarTitle.foreground": "#334248",
    "list.activeSelectionForeground": "#303f44",
    "list.activeSelectionBackground": "#cee2eb",
    "list.inactiveSelectionForeground": "#334248",
    "list.inactiveSelectionBackground": "#d3e5ed",
    "activityBar.foreground": "#334248",
    "activityBar.background": "#e5eff4",
    "statusBar.foreground": "#303f44",
    "statusBar.background": "#D1E3EB",
    "tab.activeForeground": "#303f44",
    "tab.inactiveForeground": "#869aa2",
    "titleBar.activeForeground": "#303f44",
    "titleBar.inactiveForeground": "#869aa2"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#7a8dab"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#7b9b84"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#dacbd4"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#6994a3"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#394b52"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#b58c78"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#9085b1"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#8495c0"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#a7828f"
      }
    }
  ]
}
