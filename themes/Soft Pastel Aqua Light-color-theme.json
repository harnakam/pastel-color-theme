{
  "name": "Soft Pastel Aqua Light",
  "colors": {
    "foreground": "#3b4c53",
    "editor.background": "#EAF3F7",
    "editor.foreground": "#3b4c53",
    "editor.selectionBackground": "#cee2eb",
    "editorCursor.foreground": "#91abb6",
    "editorLineNumber.foreground": "#93a0a5",
    "editorLineNumber.activeForeground": "#8ba6b2",
    "editorIndentGuide.background1": "#d9e2e7",
    "editorIndentGuide.activeBackground1": "#768e99",
    "editorWhitespace.foreground": "#dce6ea",
    "editorInlayHint.foreground": "#92A7B0",
    "editorInlayHint.background": "#e4eff4",
    "sideBar.foreground": "#3b4c53",
    "sideBar.background": "#e2eef3",
    "sideBarTitle.foreground": "#3b4c53",
    "list.activeSelectionForeground": "#36464c",
    "list.activeSelectionBackground": "#cee2eb",
    "list.inactiveSelectionForeground": "#3b4c53",
    "list.inactiveSelectionBackground": "#d3e5ed",
    "activityBar.foreground": "#3b4c53",
    "activityBar.background": "#e5eff4",
    "statusBar.foreground": "#36464c",
    "statusBar.background": "#D1E3EB",
    "tab.activeForeground": "#36464c",
    "tab.inactiveForeground": "#92A7B0",
    "titleBar.activeForeground": "#36464c",
    "titleBar.inactiveForeground": "#92A7B0"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#859bbc"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#86aa90"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#dacbd4"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#73a2b2"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#435860"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#c79a84"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#9d91c2"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#90a3d2"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#b78f9c"
      }
    }
  ]
}
