{
  "name": "Soft Pastel Aqua Light",
  "colors": {
    "foreground": "#68767d",
    "editor.background": "#EAF3F7",
    "editor.foreground": "#68767d",
    "editor.selectionBackground": "#cee2eb",
    "editorCursor.foreground": "#91abb6",
    "editorLineNumber.foreground": "#b0bbc0",
    "editorLineNumber.activeForeground": "#94acb7",
    "editorIndentGuide.background1": "#e0e9ed",
    "editorIndentGuide.activeBackground1": "#899fa9",
    "editorWhitespace.foreground": "#e2ecf0",
    "editorInlayHint.foreground": "#a2b4bc",
    "editorInlayHint.background": "#e4eff4",
    "sideBar.foreground": "#68767d",
    "sideBar.background": "#e2eef3",
    "sideBarTitle.foreground": "#68767d",
    "list.activeSelectionForeground": "#5c686e",
    "list.activeSelectionBackground": "#cee2eb",
    "list.inactiveSelectionForeground": "#68767d",
    "list.inactiveSelectionBackground": "#d3e5ed",
    "activityBar.foreground": "#68767d",
    "activityBar.background": "#e5eff4",
    "statusBar.foreground": "#5c686e",
    "statusBar.background": "#D1E3EB",
    "tab.activeForeground": "#5c686e",
    "tab.inactiveForeground": "#a2b4bc",
    "titleBar.activeForeground": "#5c686e",
    "titleBar.inactiveForeground": "#a2b4bc"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#9ab0d0"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#9bbfa6"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#dacbd4"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#88b7c7"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#6c828b"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#daaf99"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#b1a7d7"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#a5b8e6"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#cba4b2"
      }
    }
  ]
}
