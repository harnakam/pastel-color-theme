{
  "name": "Soft Pastel Yellow Dark",
  "colors": {
    "foreground": "#F5EDCF",
    "editor.background": "#4A442D",
    "editor.foreground": "#F5EDCF",
    "editor.selectionBackground": "#ab9859",
    "editorCursor.foreground": "#e9d082",
    "editorLineNumber.foreground": "#ada68b",
    "editorLineNumber.activeForeground": "#ebd58f",
    "editorIndentGuide.background1": "#625c44",
    "editorIndentGuide.activeBackground1": "#ecd794",
    "editorWhitespace.foreground": "#5b553d",
    "editorInlayHint.foreground": "#BBB07E",
    "editorInlayHint.background": "#504931",
    "sideBar.foreground": "#F5EDCF",
    "sideBar.background": "#534c33",
    "sideBarTitle.foreground": "#F5EDCF",
    "list.activeSelectionForeground": "#f6efd5",
    "list.activeSelectionBackground": "#ab9859",
    "list.inactiveSelectionForeground": "#F5EDCF",
    "list.inactiveSelectionBackground": "#897b4a",
    "activityBar.foreground": "#F5EDCF",
    "activityBar.background": "#504a31",
    "statusBar.foreground": "#f6efd5",
    "statusBar.background": "#6A6140",
    "tab.activeForeground": "#f6efd5",
    "tab.inactiveForeground": "#BBB07E",
    "titleBar.activeForeground": "#f6efd5",
    "titleBar.inactiveForeground": "#BBB07E"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#bfabda"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#acc7a0"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#c0ae89"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#9fc3d6"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#ede9cf"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#e8bb8f"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#cbbde5"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#c5cded"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#d7b2ba"
      }
    }
  ]
}
