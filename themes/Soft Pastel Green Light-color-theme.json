{
  "name": "Soft Pastel Green Light",
  "colors": {
    "foreground": "#6a756c",
    "editor.background": "#E8F3E8",
    "editor.foreground": "#6a756c",
    "editor.selectionBackground": "#cde3cf",
    "editorCursor.foreground": "#91ac94",
    "editorLineNumber.foreground": "#afbab0",
    "editorLineNumber.activeForeground": "#95ad98",
    "editorIndentGuide.background1": "#dee9de",
    "editorIndentGuide.activeBackground1": "#8a9f8d",
    "editorWhitespace.foreground": "#e0ebe1",
    "editorInlayHint.foreground": "#a2b4a4",
    "editorInlayHint.background": "#e1ede2",
    "sideBar.foreground": "#6a756c",
    "sideBar.background": "#dfece0",
    "sideBarTitle.foreground": "#6a756c",
    "list.activeSelectionForeground": "#5d675f",
    "list.activeSelectionBackground": "#cde3cf",
    "list.inactiveSelectionForeground": "#6a756c",
    "list.inactiveSelectionBackground": "#d2e6d4",
    "activityBar.foreground": "#6a756c",
    "activityBar.background": "#e2eee3",
    "statusBar.foreground": "#5d675f",
    "statusBar.background": "#CBDCCF",
    "tab.activeForeground": "#5d675f",
    "tab.inactiveForeground": "#a2b4a4",
    "titleBar.activeForeground": "#5d675f",
    "titleBar.inactiveForeground": "#a2b4a4"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#a5b5d4"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#a1c8a7"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#dcced0"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#93bccb"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#70827e"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#dbb096"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#bbb0dd"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#aec0e6"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#d0a8b7"
      }
    }
  ]
}
