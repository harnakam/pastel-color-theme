{
  "name": "Soft Pastel Green Light",
  "colors": {
    "foreground": "#3e4b40",
    "editor.background": "#E8F3E8",
    "editor.foreground": "#3e4b40",
    "editor.selectionBackground": "#cde3cf",
    "editorCursor.foreground": "#91ac94",
    "editorLineNumber.foreground": "#939f94",
    "editorLineNumber.activeForeground": "#8ca790",
    "editorIndentGuide.background1": "#d7e2d7",
    "editorIndentGuide.activeBackground1": "#788f7b",
    "editorWhitespace.foreground": "#dae6db",
    "editorInlayHint.foreground": "#92A794",
    "editorInlayHint.background": "#e1ede2",
    "sideBar.foreground": "#3e4b40",
    "sideBar.background": "#dfece0",
    "sideBarTitle.foreground": "#3e4b40",
    "list.activeSelectionForeground": "#39453b",
    "list.activeSelectionBackground": "#cde3cf",
    "list.inactiveSelectionForeground": "#3e4b40",
    "list.inactiveSelectionBackground": "#d2e6d4",
    "activityBar.foreground": "#3e4b40",
    "activityBar.background": "#e2eee3",
    "statusBar.foreground": "#39453b",
    "statusBar.background": "#CBDCCF",
    "tab.activeForeground": "#39453b",
    "tab.inactiveForeground": "#92A794",
    "titleBar.activeForeground": "#39453b",
    "titleBar.inactiveForeground": "#92A794"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#91a0c1"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#8db393"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#dcced0"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#7fa7b8"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#475850"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#c89b82"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#a79bca"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#9babd4"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#bd93a4"
      }
    }
  ]
}
