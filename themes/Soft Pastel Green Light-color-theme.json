{
  "name": "Soft Pastel Green Light",
  "colors": {
    "foreground": "#364137",
    "editor.background": "#E8F3E8",
    "editor.foreground": "#364137",
    "editor.selectionBackground": "#cde3cf",
    "editorCursor.foreground": "#91ac94",
    "editorLineNumber.foreground": "#818c81",
    "editorLineNumber.activeForeground": "#93af97",
    "editorIndentGuide.background1": "#cfdacf",
    "editorIndentGuide.activeBackground1": "#7d9580",
    "editorWhitespace.foreground": "#d3ded3",
    "editorInlayHint.foreground": "#809382",
    "editorInlayHint.background": "#e1ede2",
    "sideBar.foreground": "#364137",
    "sideBar.background": "#dfece0",
    "sideBarTitle.foreground": "#364137",
    "list.activeSelectionForeground": "#333e34",
    "list.activeSelectionBackground": "#cde3cf",
    "list.inactiveSelectionForeground": "#364137",
    "list.inactiveSelectionBackground": "#d2e6d4",
    "activityBar.foreground": "#364137",
    "activityBar.background": "#e2eee3",
    "statusBar.foreground": "#333e34",
    "statusBar.background": "#CBDCCF",
    "tab.activeForeground": "#333e34",
    "tab.inactiveForeground": "#869a88",
    "titleBar.activeForeground": "#333e34",
    "titleBar.inactiveForeground": "#869a88"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#8592b0"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#81a486"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#dcced0"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#7499a8"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#3d4a43"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#b68d76"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#998eb9"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#8d9cc1"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#ac8696"
      }
    }
  ]
}
