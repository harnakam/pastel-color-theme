{
  "name": "Soft Pastel Orange Light",
  "colors": {
    "foreground": "#796e67",
    "editor.background": "#F8EBDF",
    "editor.foreground": "#796e67",
    "editor.selectionBackground": "#ebd1bd",
    "editorCursor.foreground": "#b6957e",
    "editorLineNumber.foreground": "#bfb3a9",
    "editorLineNumber.activeForeground": "#b69986",
    "editorIndentGuide.background1": "#eee1d5",
    "editorIndentGuide.activeBackground1": "#a68e7e",
    "editorWhitespace.foreground": "#f0e3d8",
    "editorInlayHint.foreground": "#b8a093",
    "editorInlayHint.background": "#f3e3d5",
    "sideBar.foreground": "#796e67",
    "sideBar.background": "#f2e1d2",
    "sideBarTitle.foreground": "#796e67",
    "list.activeSelectionForeground": "#6a615b",
    "list.activeSelectionBackground": "#ebd1bd",
    "list.inactiveSelectionForeground": "#796e67",
    "list.inactiveSelectionBackground": "#edd6c3",
    "activityBar.foreground": "#796e67",
    "activityBar.background": "#f4e4d6",
    "statusBar.foreground": "#6a615b",
    "statusBar.background": "#E4C9B3",
    "tab.activeForeground": "#6a615b",
    "tab.inactiveForeground": "#b8a093",
    "titleBar.activeForeground": "#6a615b",
    "titleBar.inactiveForeground": "#b8a093"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#c3a7d4"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#acc59c"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#e8cac9"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#9dbdcd"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#7e7d7b"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#e4ac86"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#ccb6e0"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#bec4e5"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#d9a8b3"
      }
    }
  ]
}
