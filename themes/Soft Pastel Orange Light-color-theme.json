{
  "name": "Soft Pastel Orange Light",
  "colors": {
    "foreground": "#4f433b",
    "editor.background": "#F8EBDF",
    "editor.foreground": "#4f433b",
    "editor.selectionBackground": "#ebd1bd",
    "editorCursor.foreground": "#b6957e",
    "editorLineNumber.foreground": "#a4978d",
    "editorLineNumber.activeForeground": "#b0917c",
    "editorIndentGuide.background1": "#e7dacf",
    "editorIndentGuide.activeBackground1": "#977d6b",
    "editorWhitespace.foreground": "#eaded2",
    "editorInlayHint.foreground": "#AB8F80",
    "editorInlayHint.background": "#f3e3d5",
    "sideBar.foreground": "#4f433b",
    "sideBar.background": "#f2e1d2",
    "sideBarTitle.foreground": "#4f433b",
    "list.activeSelectionForeground": "#493e36",
    "list.activeSelectionBackground": "#ebd1bd",
    "list.inactiveSelectionForeground": "#4f433b",
    "list.inactiveSelectionBackground": "#edd6c3",
    "activityBar.foreground": "#4f433b",
    "activityBar.background": "#f4e4d6",
    "statusBar.foreground": "#493e36",
    "statusBar.background": "#E4C9B3",
    "tab.activeForeground": "#493e36",
    "tab.inactiveForeground": "#AB8F80",
    "titleBar.activeForeground": "#493e36",
    "titleBar.inactiveForeground": "#AB8F80"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#ae92c2"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#96b288"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#e8cac9"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#87a9bb"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#57514c"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#d09872"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#b7a2ce"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#a8b1d4"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#c494a0"
      }
    }
  ]
}
