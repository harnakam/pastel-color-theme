{
  "name": "Soft Pastel Orange Light",
  "colors": {
    "foreground": "#453a33",
    "editor.background": "#F8EBDF",
    "editor.foreground": "#453a33",
    "editor.selectionBackground": "#ebd1bd",
    "editorCursor.foreground": "#b6957e",
    "editorLineNumber.foreground": "#90847b",
    "editorLineNumber.activeForeground": "#b99881",
    "editorIndentGuide.background1": "#dfd2c7",
    "editorIndentGuide.activeBackground1": "#9e826f",
    "editorWhitespace.foreground": "#e3d6ca",
    "editorInlayHint.foreground": "#967e71",
    "editorInlayHint.background": "#f3e3d5",
    "sideBar.foreground": "#453a33",
    "sideBar.background": "#f2e1d2",
    "sideBarTitle.foreground": "#453a33",
    "list.activeSelectionForeground": "#423730",
    "list.activeSelectionBackground": "#ebd1bd",
    "list.inactiveSelectionForeground": "#453a33",
    "list.inactiveSelectionBackground": "#edd6c3",
    "activityBar.foreground": "#453a33",
    "activityBar.background": "#f4e4d6",
    "statusBar.foreground": "#423730",
    "statusBar.background": "#E4C9B3",
    "tab.activeForeground": "#423730",
    "tab.inactiveForeground": "#9d8476",
    "titleBar.activeForeground": "#423730",
    "titleBar.inactiveForeground": "#9d8476"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#9f86b1"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#89a27c"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#e8cac9"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#7b9bab"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#4b443f"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#be8b68"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#a794bc"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#9aa1c1"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#b38792"
      }
    }
  ]
}
