{
  "name": "Soft Pastel Pink Light",
  "colors": {
    "foreground": "#5A4951",
    "editor.background": "#F7EAF0",
    "editor.foreground": "#5A4951",
    "editor.selectionBackground": "#eacdd8",
    "editorCursor.foreground": "#b5909d",
    "editorLineNumber.foreground": "#b0a2a8",
    "editorLineNumber.activeForeground": "#a98794",
    "editorIndentGuide.background1": "#eadde3",
    "editorIndentGuide.activeBackground1": "#957783",
    "editorWhitespace.foreground": "#eee0e6",
    "editorInlayHint.foreground": "#AE919D",
    "editorInlayHint.background": "#f3e0e8",
    "sideBar.foreground": "#5A4951",
    "sideBar.background": "#f2dee6",
    "sideBarTitle.foreground": "#5A4951",
    "list.activeSelectionForeground": "#4f4047",
    "list.activeSelectionBackground": "#eacdd8",
    "list.inactiveSelectionForeground": "#5A4951",
    "list.inactiveSelectionBackground": "#ecd2dc",
    "activityBar.foreground": "#5A4951",
    "activityBar.background": "#f4e2e9",
    "statusBar.foreground": "#4f4047",
    "statusBar.background": "#E5C7D3",
    "tab.activeForeground": "#4f4047",
    "tab.inactiveForeground": "#AE919D",
    "titleBar.activeForeground": "#4f4047",
    "titleBar.inactiveForeground": "#AE919D"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#bc9ad0"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#a1bf9a"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#edccda"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#90b6cc"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#635b65"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#daac98"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#c1a9dc"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#b0b8e4"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#d7a0b6"
      }
    }
  ]
}
