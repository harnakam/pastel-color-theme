{
  "name": "Soft Pastel Pink Light",
  "colors": {
    "foreground": "#7b6d74",
    "editor.background": "#F7EAF0",
    "editor.foreground": "#7b6d74",
    "editor.selectionBackground": "#eacdd8",
    "editorCursor.foreground": "#b5909d",
    "editorLineNumber.foreground": "#bfb2b8",
    "editorLineNumber.activeForeground": "#b695a2",
    "editorIndentGuide.background1": "#ede0e6",
    "editorIndentGuide.activeBackground1": "#a78b96",
    "editorWhitespace.foreground": "#f0e2e9",
    "editorInlayHint.foreground": "#baa2ac",
    "editorInlayHint.background": "#f3e0e8",
    "sideBar.foreground": "#7b6d74",
    "sideBar.background": "#f2dee6",
    "sideBarTitle.foreground": "#7b6d74",
    "list.activeSelectionForeground": "#6c6066",
    "list.activeSelectionBackground": "#eacdd8",
    "list.inactiveSelectionForeground": "#7b6d74",
    "list.inactiveSelectionBackground": "#ecd2dc",
    "activityBar.foreground": "#7b6d74",
    "activityBar.background": "#f4e2e9",
    "statusBar.foreground": "#6c6066",
    "statusBar.background": "#E5C7D3",
    "tab.activeForeground": "#6c6066",
    "tab.inactiveForeground": "#baa2ac",
    "titleBar.activeForeground": "#6c6066",
    "titleBar.inactiveForeground": "#baa2ac"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#c9a7db"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#b0cba8"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#edccda"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#a0c2d7"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#807d87"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#e5b9a6"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#ceb6e6"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#bdc4ed"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#e2aec3"
      }
    }
  ]
}
