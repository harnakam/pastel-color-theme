{
  "name": "Soft Pastel Pink Light",
  "colors": {
    "foreground": "#514249",
    "editor.background": "#F7EAF0",
    "editor.foreground": "#514249",
    "editor.selectionBackground": "#eacdd8",
    "editorCursor.foreground": "#b5909d",
    "editorLineNumber.foreground": "#a4969d",
    "editorLineNumber.activeForeground": "#b08d9a",
    "editorIndentGuide.background1": "#e6d9df",
    "editorIndentGuide.activeBackground1": "#977985",
    "editorWhitespace.foreground": "#eadde3",
    "editorInlayHint.foreground": "#AE919D",
    "editorInlayHint.background": "#f3e0e8",
    "sideBar.foreground": "#514249",
    "sideBar.background": "#f2dee6",
    "sideBarTitle.foreground": "#514249",
    "list.activeSelectionForeground": "#4b3d43",
    "list.activeSelectionBackground": "#eacdd8",
    "list.inactiveSelectionForeground": "#514249",
    "list.inactiveSelectionBackground": "#ecd2dc",
    "activityBar.foreground": "#514249",
    "activityBar.background": "#f4e2e9",
    "statusBar.foreground": "#4b3d43",
    "statusBar.background": "#E5C7D3",
    "tab.activeForeground": "#4b3d43",
    "tab.inactiveForeground": "#AE919D",
    "titleBar.activeForeground": "#4b3d43",
    "titleBar.inactiveForeground": "#AE919D"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#b493c8"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#9bb793"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#edccda"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#8aafc3"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#59515a"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#d1a591"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#b9a2d3"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#a8b1da"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#ce9aaf"
      }
    }
  ]
}
