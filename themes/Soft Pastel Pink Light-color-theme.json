{
  "name": "Soft Pastel Pink Light",
  "colors": {
    "foreground": "#46393f",
    "editor.background": "#F7EAF0",
    "editor.foreground": "#46393f",
    "editor.selectionBackground": "#eacdd8",
    "editorCursor.foreground": "#b5909d",
    "editorLineNumber.foreground": "#908389",
    "editorLineNumber.activeForeground": "#b993a1",
    "editorIndentGuide.background1": "#ded1d7",
    "editorIndentGuide.activeBackground1": "#9e7e8a",
    "editorWhitespace.foreground": "#e2d5db",
    "editorInlayHint.foreground": "#99808a",
    "editorInlayHint.background": "#f3e0e8",
    "sideBar.foreground": "#46393f",
    "sideBar.background": "#f2dee6",
    "sideBarTitle.foreground": "#46393f",
    "list.activeSelectionForeground": "#43363c",
    "list.activeSelectionBackground": "#eacdd8",
    "list.inactiveSelectionForeground": "#46393f",
    "list.inactiveSelectionBackground": "#ecd2dc",
    "activityBar.foreground": "#46393f",
    "activityBar.background": "#f4e2e9",
    "statusBar.foreground": "#43363c",
    "statusBar.background": "#E5C7D3",
    "tab.activeForeground": "#43363c",
    "tab.inactiveForeground": "#a08590",
    "titleBar.activeForeground": "#43363c",
    "titleBar.inactiveForeground": "#a08590"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#a586b6"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#8da786"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#edccda"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#7ea0b2"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#4c444b"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#bf9685"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#a994c0"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#9aa1c7"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#bc8ca0"
      }
    }
  ]
}
