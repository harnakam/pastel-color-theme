{
  "name": "Soft Pastel Black Dark",
  "colors": {
    "foreground": "#DCE4E9",
    "editor.background": "#2B3137",
    "editor.foreground": "#DCE4E9",
    "editor.selectionBackground": "#7f8a96",
    "editorCursor.foreground": "#bbc6d5",
    "editorLineNumber.foreground": "#92999e",
    "editorLineNumber.activeForeground": "#bfcbd8",
    "editorIndentGuide.background1": "#444a50",
    "editorIndentGuide.activeBackground1": "#c1cdd9",
    "editorWhitespace.foreground": "#3d4349",
    "editorInlayHint.foreground": "#96A0AA",
    "editorInlayHint.background": "#30373e",
    "sideBar.foreground": "#DCE4E9",
    "sideBar.background": "#333a41",
    "sideBarTitle.foreground": "#DCE4E9",
    "list.activeSelectionForeground": "#e0e7ec",
    "list.activeSelectionBackground": "#7f8a96",
    "list.inactiveSelectionForeground": "#DCE4E9",
    "list.inactiveSelectionBackground": "#626b75",
    "activityBar.foreground": "#DCE4E9",
    "activityBar.background": "#30373e",
    "statusBar.foreground": "#e0e7ec",
    "statusBar.background": "#454E56",
    "tab.activeForeground": "#e0e7ec",
    "tab.inactiveForeground": "#96A0AA",
    "titleBar.activeForeground": "#e0e7ec",
    "titleBar.inactiveForeground": "#96A0AA"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#b5c3d5"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#abc2b2"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#9fa1ab"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#a2bbcd"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#d6e0e6"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#d8b6a4"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#bcb4d6"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#b8c2de"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#c9b0bb"
      }
    }
  ]
}
