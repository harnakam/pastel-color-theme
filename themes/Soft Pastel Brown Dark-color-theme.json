{
  "name": "Soft Pastel Brown Dark",
  "colors": {
    "foreground": "#E8DED8",
    "editor.background": "#40352F",
    "editor.foreground": "#E8DED8",
    "editor.selectionBackground": "#9b8171",
    "editorCursor.foreground": "#d7b8a4",
    "editorLineNumber.foreground": "#a19791",
    "editorLineNumber.activeForeground": "#d9bead",
    "editorIndentGuide.background1": "#584d47",
    "editorIndentGuide.activeBackground1": "#dac0b0",
    "editorWhitespace.foreground": "#514640",
    "editorInlayHint.foreground": "#B0988B",
    "editorInlayHint.background": "#473a34",
    "sideBar.foreground": "#E8DED8",
    "sideBar.background": "#4a3d36",
    "sideBarTitle.foreground": "#E8DED8",
    "list.activeSelectionForeground": "#ebe2dd",
    "list.activeSelectionBackground": "#9b8171",
    "list.inactiveSelectionForeground": "#E8DED8",
    "list.inactiveSelectionBackground": "#7b665a",
    "activityBar.foreground": "#E8DED8",
    "activityBar.background": "#473a34",
    "statusBar.foreground": "#ebe2dd",
    "statusBar.background": "#635049",
    "tab.activeForeground": "#ebe2dd",
    "tab.inactiveForeground": "#B0988B",
    "titleBar.activeForeground": "#ebe2dd",
    "titleBar.inactiveForeground": "#B0988B"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#bfacd9"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#b2caa9"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#b79a92"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#a4c1d4"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#e1dbd7"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#dead91"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#c9bae3"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#c0c9e9"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#d7aeb8"
      }
    }
  ]
}
