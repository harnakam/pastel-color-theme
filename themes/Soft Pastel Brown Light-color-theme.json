{
  "name": "Soft Pastel Brown Light",
  "colors": {
    "foreground": "#433a34",
    "editor.background": "#F0E6DD",
    "editor.foreground": "#433a34",
    "editor.selectionBackground": "#e0cec0",
    "editorCursor.foreground": "#aa9485",
    "editorLineNumber.foreground": "#8c827b",
    "editorLineNumber.activeForeground": "#ad9788",
    "editorIndentGuide.background1": "#d8cec5",
    "editorIndentGuide.activeBackground1": "#948174",
    "editorWhitespace.foreground": "#dbd1c9",
    "editorInlayHint.foreground": "#8f7b70",
    "editorInlayHint.background": "#eaded3",
    "sideBar.foreground": "#433a34",
    "sideBar.background": "#e9dcd1",
    "sideBarTitle.foreground": "#433a34",
    "list.activeSelectionForeground": "#403731",
    "list.activeSelectionBackground": "#e0cec0",
    "list.inactiveSelectionForeground": "#433a34",
    "list.inactiveSelectionBackground": "#e3d2c5",
    "activityBar.foreground": "#433a34",
    "activityBar.background": "#ebdfd5",
    "statusBar.foreground": "#403731",
    "statusBar.background": "#D9C4B5",
    "tab.activeForeground": "#403731",
    "tab.inactiveForeground": "#958175",
    "titleBar.activeForeground": "#403731",
    "titleBar.inactiveForeground": "#958175"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#9886b1"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#8ba282"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#e2c7c7"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#7d9aac"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#4a4440"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#b6866b"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#a193ba"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#99a1c0"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#af8791"
      }
    }
  ]
}
