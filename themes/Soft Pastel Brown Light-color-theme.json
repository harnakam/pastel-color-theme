{
  "name": "Soft Pastel Brown Light",
  "colors": {
    "foreground": "#4d433c",
    "editor.background": "#F0E6DD",
    "editor.foreground": "#4d433c",
    "editor.selectionBackground": "#e0cec0",
    "editorCursor.foreground": "#aa9485",
    "editorLineNumber.foreground": "#9f958d",
    "editorLineNumber.activeForeground": "#a59181",
    "editorIndentGuide.background1": "#e0d6cd",
    "editorIndentGuide.activeBackground1": "#8e7c6f",
    "editorWhitespace.foreground": "#e3d9d0",
    "editorInlayHint.foreground": "#A28C7F",
    "editorInlayHint.background": "#eaded3",
    "sideBar.foreground": "#4d433c",
    "sideBar.background": "#e9dcd1",
    "sideBarTitle.foreground": "#4d433c",
    "list.activeSelectionForeground": "#473e37",
    "list.activeSelectionBackground": "#e0cec0",
    "list.inactiveSelectionForeground": "#4d433c",
    "list.inactiveSelectionBackground": "#e3d2c5",
    "activityBar.foreground": "#4d433c",
    "activityBar.background": "#ebdfd5",
    "statusBar.foreground": "#473e37",
    "statusBar.background": "#D9C4B5",
    "tab.activeForeground": "#473e37",
    "tab.inactiveForeground": "#A28C7F",
    "titleBar.activeForeground": "#473e37",
    "titleBar.inactiveForeground": "#A28C7F"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#a792c2"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#98b28f"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#e2c7c7"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#89a8bd"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#56514d"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#c89375"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#b1a1cc"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#a7b1d3"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#bf949f"
      }
    }
  ]
}
