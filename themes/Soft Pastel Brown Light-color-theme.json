{
  "name": "Soft Pastel Brown Light",
  "colors": {
    "foreground": "#786e69",
    "editor.background": "#F0E6DD",
    "editor.foreground": "#786e69",
    "editor.selectionBackground": "#e0cec0",
    "editorCursor.foreground": "#aa9485",
    "editorLineNumber.foreground": "#bab0a9",
    "editorLineNumber.activeForeground": "#ac998b",
    "editorIndentGuide.background1": "#e6dcd4",
    "editorIndentGuide.activeBackground1": "#9f8e83",
    "editorWhitespace.foreground": "#e9dfd6",
    "editorInlayHint.foreground": "#b09d92",
    "editorInlayHint.background": "#eaded3",
    "sideBar.foreground": "#786e69",
    "sideBar.background": "#e9dcd1",
    "sideBarTitle.foreground": "#786e69",
    "list.activeSelectionForeground": "#6a615c",
    "list.activeSelectionBackground": "#e0cec0",
    "list.inactiveSelectionForeground": "#786e69",
    "list.inactiveSelectionBackground": "#e3d2c5",
    "activityBar.foreground": "#786e69",
    "activityBar.background": "#ebdfd5",
    "statusBar.foreground": "#6a615c",
    "statusBar.background": "#D9C4B5",
    "tab.activeForeground": "#6a615c",
    "tab.inactiveForeground": "#b09d92",
    "titleBar.activeForeground": "#6a615c",
    "titleBar.inactiveForeground": "#b09d92"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#bba6d4"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#adc5a2"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#e2c7c7"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#9ebccf"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#7e7d7d"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#dba788"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#c5b5de"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#bcc4e4"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#d3a8b2"
      }
    }
  ]
}
