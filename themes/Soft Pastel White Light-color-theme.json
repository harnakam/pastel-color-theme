{
  "name": "Soft Pastel White Light",
  "colors": {
    "foreground": "#49423d",
    "editor.background": "#EEE7E0",
    "editor.foreground": "#49423d",
    "editor.selectionBackground": "#d8dbdf",
    "editorCursor.foreground": "#9faab6",
    "editorLineNumber.foreground": "#9c958f",
    "editorLineNumber.activeForeground": "#9ba2aa",
    "editorIndentGuide.background1": "#ded7d0",
    "editorIndentGuide.activeBackground1": "#86898e",
    "editorWhitespace.foreground": "#e1dad3",
    "editorInlayHint.foreground": "#A8998F",
    "editorInlayHint.background": "#e8e1d9",
    "sideBar.foreground": "#49423d",
    "sideBar.background": "#e7dfd7",
    "sideBarTitle.foreground": "#49423d",
    "list.activeSelectionForeground": "#433d38",
    "list.activeSelectionBackground": "#d8dbdf",
    "list.inactiveSelectionForeground": "#49423d",
    "list.inactiveSelectionBackground": "#dcdddf",
    "activityBar.foreground": "#49423d",
    "activityBar.background": "#e9e1da",
    "statusBar.foreground": "#433d38",
    "statusBar.background": "#DCCFC5",
    "tab.activeForeground": "#433d38",
    "tab.inactiveForeground": "#A8998F",
    "titleBar.activeForeground": "#433d38",
    "titleBar.inactiveForeground": "#A8998F"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#a290b9"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#8aa480"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#dcc6ca"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#7ea1bb"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#514f4e"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#c29580"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#9b8ec0"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#9ba8cd"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#b590a0"
      }
    }
  ]
}
