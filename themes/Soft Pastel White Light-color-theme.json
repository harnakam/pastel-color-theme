{
  "name": "Soft Pastel White Light",
  "colors": {
    "foreground": "#746d69",
    "editor.background": "#EEE7E0",
    "editor.foreground": "#746d69",
    "editor.selectionBackground": "#d8dbdf",
    "editorCursor.foreground": "#9faab6",
    "editorLineNumber.foreground": "#b7b0aa",
    "editorLineNumber.activeForeground": "#a3a8af",
    "editorIndentGuide.background1": "#e4ddd6",
    "editorIndentGuide.activeBackground1": "#97999e",
    "editorWhitespace.foreground": "#e7e0d9",
    "editorInlayHint.foreground": "#b5a8a0",
    "editorInlayHint.background": "#e8e1d9",
    "sideBar.foreground": "#746d69",
    "sideBar.background": "#e7dfd7",
    "sideBarTitle.foreground": "#746d69",
    "list.activeSelectionForeground": "#66605c",
    "list.activeSelectionBackground": "#d8dbdf",
    "list.inactiveSelectionForeground": "#746d69",
    "list.inactiveSelectionBackground": "#dcdddf",
    "activityBar.foreground": "#746d69",
    "activityBar.background": "#e9e1da",
    "statusBar.foreground": "#66605c",
    "statusBar.background": "#DCCFC5",
    "tab.activeForeground": "#66605c",
    "tab.inactiveForeground": "#b5a8a0",
    "titleBar.activeForeground": "#66605c",
    "titleBar.inactiveForeground": "#b5a8a0"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#b6a4cb"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#9fb794"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#dcc6ca"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#93b5cd"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#787a7d"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#d6a994"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#afa2d3"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#b0bcdf"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#c9a4b3"
      }
    }
  ]
}
