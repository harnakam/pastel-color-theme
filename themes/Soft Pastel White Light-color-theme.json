{
  "name": "Soft Pastel White Light",
  "colors": {
    "foreground": "#3f3935",
    "editor.background": "#EEE7E0",
    "editor.foreground": "#3f3935",
    "editor.selectionBackground": "#d8dbdf",
    "editorCursor.foreground": "#9faab6",
    "editorLineNumber.foreground": "#89827d",
    "editorLineNumber.activeForeground": "#a3abb5",
    "editorIndentGuide.background1": "#d6cfc8",
    "editorIndentGuide.activeBackground1": "#8b9097",
    "editorWhitespace.foreground": "#d9d2cb",
    "editorInlayHint.foreground": "#94877e",
    "editorInlayHint.background": "#e8e1d9",
    "sideBar.foreground": "#3f3935",
    "sideBar.background": "#e7dfd7",
    "sideBarTitle.foreground": "#3f3935",
    "list.activeSelectionForeground": "#3c3632",
    "list.activeSelectionBackground": "#d8dbdf",
    "list.inactiveSelectionForeground": "#3f3935",
    "list.inactiveSelectionBackground": "#dcdddf",
    "activityBar.foreground": "#3f3935",
    "activityBar.background": "#e9e1da",
    "statusBar.foreground": "#3c3632",
    "statusBar.background": "#DCCFC5",
    "tab.activeForeground": "#3c3632",
    "tab.inactiveForeground": "#9b8d84",
    "titleBar.activeForeground": "#3c3632",
    "titleBar.inactiveForeground": "#9b8d84"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#9483a9"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#7e9675"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#dcc6ca"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#7393ab"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#454241"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#b18875"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#8d81b0"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#8e9abb"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#a58492"
      }
    }
  ]
}
