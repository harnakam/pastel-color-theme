{
  "name": "Soft Pastel Gray Light",
  "colors": {
    "foreground": "#6c6f75",
    "editor.background": "#E8EAEE",
    "editor.foreground": "#6c6f75",
    "editor.selectionBackground": "#d5d9e0",
    "editorCursor.foreground": "#9ea4ab",
    "editorLineNumber.foreground": "#b0b3b8",
    "editorLineNumber.activeForeground": "#9fa4ac",
    "editorIndentGuide.background1": "#dee0e4",
    "editorIndentGuide.activeBackground1": "#92979e",
    "editorWhitespace.foreground": "#e1e3e7",
    "editorInlayHint.foreground": "#a4abb3",
    "editorInlayHint.background": "#e1e4e9",
    "sideBar.foreground": "#6c6f75",
    "sideBar.background": "#dfe2e8",
    "sideBarTitle.foreground": "#6c6f75",
    "list.activeSelectionForeground": "#5f6267",
    "list.activeSelectionBackground": "#d5d9e0",
    "list.inactiveSelectionForeground": "#6c6f75",
    "list.inactiveSelectionBackground": "#d8dce3",
    "activityBar.foreground": "#6c6f75",
    "activityBar.background": "#e2e5ea",
    "statusBar.foreground": "#5f6267",
    "statusBar.background": "#CDD3DB",
    "tab.activeForeground": "#5f6267",
    "tab.inactiveForeground": "#a4abb3",
    "titleBar.activeForeground": "#5f6267",
    "titleBar.inactiveForeground": "#a4abb3"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#afb8d5"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#a9c2af"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#d9ccd4"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#9dbace"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#747d86"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#d5b09e"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#bcb4d8"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#b6c1e1"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#c9afba"
      }
    }
  ]
}
