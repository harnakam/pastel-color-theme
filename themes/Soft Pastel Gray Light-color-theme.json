{
  "name": "Soft Pastel Gray Light",
  "colors": {
    "foreground": "#373b40",
    "editor.background": "#E8EAEE",
    "editor.foreground": "#373b40",
    "editor.selectionBackground": "#d5d9e0",
    "editorCursor.foreground": "#9ea4ab",
    "editorLineNumber.foreground": "#818589",
    "editorLineNumber.activeForeground": "#a0a6ae",
    "editorIndentGuide.background1": "#cfd2d6",
    "editorIndentGuide.activeBackground1": "#878d94",
    "editorWhitespace.foreground": "#d3d5d9",
    "editorInlayHint.foreground": "#828991",
    "editorInlayHint.background": "#e1e4e9",
    "sideBar.foreground": "#373b40",
    "sideBar.background": "#dfe2e8",
    "sideBarTitle.foreground": "#373b40",
    "list.activeSelectionForeground": "#34383d",
    "list.activeSelectionBackground": "#d5d9e0",
    "list.inactiveSelectionForeground": "#373b40",
    "list.inactiveSelectionBackground": "#d8dce3",
    "activityBar.foreground": "#373b40",
    "activityBar.background": "#e2e5ea",
    "statusBar.foreground": "#34383d",
    "statusBar.background": "#CDD3DB",
    "tab.activeForeground": "#34383d",
    "tab.inactiveForeground": "#889098",
    "titleBar.activeForeground": "#34383d",
    "titleBar.inactiveForeground": "#889098"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#8e96b0"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#88a08d"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#d9ccd4"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#7d98aa"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#3f454b"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#b18f7d"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#9a92b4"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#949ebc"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#a68d97"
      }
    }
  ]
}
