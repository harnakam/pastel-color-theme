{
  "name": "Soft Pastel Gray Light",
  "colors": {
    "foreground": "#40444a",
    "editor.background": "#E8EAEE",
    "editor.foreground": "#40444a",
    "editor.selectionBackground": "#d5d9e0",
    "editorCursor.foreground": "#9ea4ab",
    "editorLineNumber.foreground": "#94979c",
    "editorLineNumber.activeForeground": "#989ea6",
    "editorIndentGuide.background1": "#d7d9de",
    "editorIndentGuide.activeBackground1": "#81868e",
    "editorWhitespace.foreground": "#dbdde1",
    "editorInlayHint.foreground": "#949CA5",
    "editorInlayHint.background": "#e1e4e9",
    "sideBar.foreground": "#40444a",
    "sideBar.background": "#dfe2e8",
    "sideBarTitle.foreground": "#40444a",
    "list.activeSelectionForeground": "#3b3f44",
    "list.activeSelectionBackground": "#d5d9e0",
    "list.inactiveSelectionForeground": "#40444a",
    "list.inactiveSelectionBackground": "#d8dce3",
    "activityBar.foreground": "#40444a",
    "activityBar.background": "#e2e5ea",
    "statusBar.foreground": "#3b3f44",
    "statusBar.background": "#CDD3DB",
    "tab.activeForeground": "#3b3f44",
    "tab.inactiveForeground": "#949CA5",
    "titleBar.activeForeground": "#3b3f44",
    "titleBar.inactiveForeground": "#949CA5"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#9ba4c1"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#95af9b"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#d9ccd4"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#89a7ba"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#4a5259"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#c29c89"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#a8a0c5"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#a2adce"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#b69ba6"
      }
    }
  ]
}
