{
  "name": "Soft Pastel Pink Dark",
  "colors": {
    "foreground": "#F4E6EC",
    "editor.background": "#473640",
    "editor.foreground": "#F4E6EC",
    "editor.selectionBackground": "#a87d8e",
    "editorCursor.foreground": "#e6b2c5",
    "editorLineNumber.foreground": "#ab9ca4",
    "editorLineNumber.activeForeground": "#e8bbcc",
    "editorIndentGuide.background1": "#5f4f58",
    "editorIndentGuide.activeBackground1": "#e9bece",
    "editorWhitespace.foreground": "#584851",
    "editorInlayHint.foreground": "#B999A6",
    "editorInlayHint.background": "#4e3b45",
    "sideBar.foreground": "#F4E6EC",
    "sideBar.background": "#513d48",
    "sideBarTitle.foreground": "#F4E6EC",
    "list.activeSelectionForeground": "#f5e9ee",
    "list.activeSelectionBackground": "#a87d8e",
    "list.inactiveSelectionForeground": "#F4E6EC",
    "list.inactiveSelectionBackground": "#866473",
    "activityBar.foreground": "#F4E6EC",
    "activityBar.background": "#4e3b46",
    "statusBar.foreground": "#f5e9ee",
    "statusBar.background": "#694C59",
    "tab.activeForeground": "#f5e9ee",
    "tab.inactiveForeground": "#B999A6",
    "titleBar.activeForeground": "#f5e9ee",
    "titleBar.inactiveForeground": "#B999A6"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#ccadde"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#b4cfad"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#c29cab"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#a5c7da"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#ece3ea"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#e7beac"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#d1bbe9"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#c1c9f0"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#e4b3c7"
      }
    }
  ]
}
