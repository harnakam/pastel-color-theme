{
  "name": "Soft Pastel White Dark",
  "colors": {
    "foreground": "#E8DFD9",
    "editor.background": "#3A3532",
    "editor.foreground": "#E8DFD9",
    "editor.selectionBackground": "#989ea5",
    "editorCursor.foreground": "#d7e2ee",
    "editorLineNumber.foreground": "#9f9893",
    "editorLineNumber.activeForeground": "#d9dfe6",
    "editorIndentGuide.background1": "#524d49",
    "editorIndentGuide.activeBackground1": "#dadfe5",
    "editorWhitespace.foreground": "#4b4643",
    "editorInlayHint.foreground": "#B1A39A",
    "editorInlayHint.background": "#403a37",
    "sideBar.foreground": "#E8DFD9",
    "sideBar.background": "#433d3a",
    "sideBarTitle.foreground": "#E8DFD9",
    "list.activeSelectionForeground": "#ebe3de",
    "list.activeSelectionBackground": "#989ea5",
    "list.inactiveSelectionForeground": "#E8DFD9",
    "list.inactiveSelectionBackground": "#77797d",
    "activityBar.foreground": "#E8DFD9",
    "activityBar.background": "#403b37",
    "statusBar.foreground": "#ebe3de",
    "statusBar.background": "#554D48",
    "tab.activeForeground": "#ebe3de",
    "tab.inactiveForeground": "#B1A39A",
    "titleBar.activeForeground": "#ebe3de",
    "titleBar.inactiveForeground": "#B1A39A"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#bbaad1"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#a5bd9b"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#b5a29e"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#9abad2"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#e0dbd8"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#d9af9b"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#b4a8d7"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#b5c1e3"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#cdabb9"
      }
    }
  ]
}
