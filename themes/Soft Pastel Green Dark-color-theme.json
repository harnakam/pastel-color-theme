{
  "name": "Soft Pastel Green Dark",
  "colors": {
    "foreground": "#DDE9DF",
    "editor.background": "#304035",
    "editor.foreground": "#DDE9DF",
    "editor.selectionBackground": "#7c9e80",
    "editorCursor.foreground": "#b3dbb6",
    "editorLineNumber.foreground": "#94a298",
    "editorLineNumber.activeForeground": "#b9dcbd",
    "editorIndentGuide.background1": "#48584d",
    "editorIndentGuide.activeBackground1": "#bcddbf",
    "editorWhitespace.foreground": "#415146",
    "editorInlayHint.foreground": "#97B19A",
    "editorInlayHint.background": "#35473b",
    "sideBar.foreground": "#DDE9DF",
    "sideBar.background": "#384a3e",
    "sideBarTitle.foreground": "#DDE9DF",
    "list.activeSelectionForeground": "#e1ece3",
    "list.activeSelectionBackground": "#7c9e80",
    "list.inactiveSelectionForeground": "#DDE9DF",
    "list.inactiveSelectionBackground": "#617d66",
    "activityBar.foreground": "#DDE9DF",
    "activityBar.background": "#36473b",
    "statusBar.foreground": "#e1ece3",
    "statusBar.background": "#506554",
    "tab.activeForeground": "#e1ece3",
    "tab.inactiveForeground": "#97B19A",
    "titleBar.activeForeground": "#e1ece3",
    "titleBar.inactiveForeground": "#97B19A"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#acb9d8"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#a7cbad"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#a3ad9f"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#9ac0d0"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#d6e5dd"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#deb49d"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#c0b5e1"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#b4c4ea"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#d4adbd"
      }
    }
  ]
}
