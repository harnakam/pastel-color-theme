{
  "name": "Soft Pastel Gray Dark",
  "colors": {
    "foreground": "#DEE2E8",
    "editor.background": "#34383E",
    "editor.foreground": "#DEE2E8",
    "editor.selectionBackground": "#8a919a",
    "editorCursor.foreground": "#c5cdd7",
    "editorLineNumber.foreground": "#979ba1",
    "editorLineNumber.activeForeground": "#c8cfd9",
    "editorIndentGuide.background1": "#4c5056",
    "editorIndentGuide.activeBackground1": "#c9d0da",
    "editorWhitespace.foreground": "#45494f",
    "editorInlayHint.foreground": "#9CA3AF",
    "editorInlayHint.background": "#3a3e45",
    "sideBar.foreground": "#DEE2E8",
    "sideBar.background": "#3d4148",
    "sideBarTitle.foreground": "#DEE2E8",
    "list.activeSelectionForeground": "#e2e5eb",
    "list.activeSelectionBackground": "#8a919a",
    "list.inactiveSelectionForeground": "#DEE2E8",
    "list.inactiveSelectionBackground": "#6c727a",
    "activityBar.foreground": "#DEE2E8",
    "activityBar.background": "#3a3e45",
    "statusBar.foreground": "#e2e5eb",
    "statusBar.background": "#545A63",
    "tab.activeForeground": "#e2e5eb",
    "tab.inactiveForeground": "#9CA3AF",
    "titleBar.activeForeground": "#e2e5eb",
    "titleBar.inactiveForeground": "#9CA3AF"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#b5bdd8"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#afc7b4"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#a5a4b0"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#a4bfd1"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#d8dee6"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#d9b6a4"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#c1b9dc"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#bbc5e4"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#ceb4bf"
      }
    }
  ]
}
