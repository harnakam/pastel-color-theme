{
  "name": "Soft Pastel Orange Dark",
  "colors": {
    "foreground": "#F0E1D9",
    "editor.background": "#44342D",
    "editor.foreground": "#F0E1D9",
    "editor.selectionBackground": "#a78269",
    "editorCursor.foreground": "#e7b998",
    "editorLineNumber.foreground": "#a89891",
    "editorLineNumber.activeForeground": "#e8bfa4",
    "editorIndentGuide.background1": "#5c4c45",
    "editorIndentGuide.activeBackground1": "#e8c2a8",
    "editorWhitespace.foreground": "#55453e",
    "editorInlayHint.foreground": "#BA9B8C",
    "editorInlayHint.background": "#4b3932",
    "sideBar.foreground": "#F0E1D9",
    "sideBar.background": "#4e3c35",
    "sideBarTitle.foreground": "#F0E1D9",
    "list.activeSelectionForeground": "#f2e5de",
    "list.activeSelectionBackground": "#a78269",
    "list.inactiveSelectionForeground": "#F0E1D9",
    "list.inactiveSelectionBackground": "#846754",
    "activityBar.foreground": "#F0E1D9",
    "activityBar.background": "#4b3a32",
    "statusBar.foreground": "#f2e5de",
    "statusBar.background": "#685046",
    "tab.activeForeground": "#f2e5de",
    "tab.inactiveForeground": "#BA9B8C",
    "titleBar.activeForeground": "#f2e5de",
    "titleBar.inactiveForeground": "#BA9B8C"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#c6acd9"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#b0caa3"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#c09c93"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#a2c2d2"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#e9ded8"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#e6b28e"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#cfbbe4"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#c1c9ea"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#dbaeb9"
      }
    }
  ]
}
