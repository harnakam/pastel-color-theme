{
  "name": "Soft Pastel Yellow Light",
  "colors": {
    "foreground": "#7a7468",
    "editor.background": "#F7F0D8",
    "editor.foreground": "#7a7468",
    "editor.selectionBackground": "#ebddb4",
    "editorCursor.foreground": "#b7a575",
    "editorLineNumber.foreground": "#bfb8a6",
    "editorLineNumber.activeForeground": "#b7a77f",
    "editorIndentGuide.background1": "#ede6cf",
    "editorIndentGuide.activeBackground1": "#a79a7a",
    "editorWhitespace.foreground": "#efe9d1",
    "editorInlayHint.foreground": "#b7aa8d",
    "editorInlayHint.background": "#f3eaca",
    "sideBar.foreground": "#7a7468",
    "sideBar.background": "#f2e8c6",
    "sideBarTitle.foreground": "#7a7468",
    "list.activeSelectionForeground": "#6b665c",
    "list.activeSelectionBackground": "#ebddb4",
    "list.inactiveSelectionForeground": "#7a7468",
    "list.inactiveSelectionBackground": "#ede0ba",
    "activityBar.foreground": "#7a7468",
    "activityBar.background": "#f3eacc",
    "statusBar.foreground": "#6b665c",
    "statusBar.background": "#E4D4A6",
    "tab.activeForeground": "#6b665c",
    "tab.inactiveForeground": "#b7aa8d",
    "titleBar.activeForeground": "#6b665c",
    "titleBar.inactiveForeground": "#b7aa8d"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#bca5d4"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#a8c398"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#e5cec6"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#99bfd0"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#7e827d"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#e6b686"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#c7b8e0"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#c2c9e8"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#d4adb3"
      }
    }
  ]
}
