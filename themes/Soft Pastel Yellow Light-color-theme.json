{
  "name": "Soft Pastel Yellow Light",
  "colors": {
    "foreground": "#453f33",
    "editor.background": "#F7F0D8",
    "editor.foreground": "#453f33",
    "editor.selectionBackground": "#ebddb4",
    "editorCursor.foreground": "#b7a575",
    "editorLineNumber.foreground": "#908978",
    "editorLineNumber.activeForeground": "#baa879",
    "editorIndentGuide.background1": "#ded7c1",
    "editorIndentGuide.activeBackground1": "#9e8f68",
    "editorWhitespace.foreground": "#e2dbc4",
    "editorInlayHint.foreground": "#96886a",
    "editorInlayHint.background": "#f3eaca",
    "sideBar.foreground": "#453f33",
    "sideBar.background": "#f2e8c6",
    "sideBarTitle.foreground": "#453f33",
    "list.activeSelectionForeground": "#423c30",
    "list.activeSelectionBackground": "#ebddb4",
    "list.inactiveSelectionForeground": "#453f33",
    "list.inactiveSelectionBackground": "#ede0ba",
    "activityBar.foreground": "#453f33",
    "activityBar.background": "#f3eacc",
    "statusBar.foreground": "#423c30",
    "statusBar.background": "#E4D4A6",
    "tab.activeForeground": "#423c30",
    "tab.inactiveForeground": "#9c8f6f",
    "titleBar.activeForeground": "#423c30",
    "titleBar.inactiveForeground": "#9c8f6f"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#9884b2"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#86a07a"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#e5cec6"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#789bae"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#4b493f"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#c09469"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#a396bd"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#9ea5c5"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#af8b93"
      }
    }
  ]
}
