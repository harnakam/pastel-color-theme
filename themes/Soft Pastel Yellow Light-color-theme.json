{
  "name": "Soft Pastel Yellow Light",
  "colors": {
    "foreground": "#50493b",
    "editor.background": "#F7F0D8",
    "editor.foreground": "#50493b",
    "editor.selectionBackground": "#ebddb4",
    "editorCursor.foreground": "#b7a575",
    "editorLineNumber.foreground": "#a49d8a",
    "editorLineNumber.activeForeground": "#b1a074",
    "editorIndentGuide.background1": "#e6dfc8",
    "editorIndentGuide.activeBackground1": "#988965",
    "editorWhitespace.foreground": "#eae3cb",
    "editorInlayHint.foreground": "#AA9B79",
    "editorInlayHint.background": "#f3eaca",
    "sideBar.foreground": "#50493b",
    "sideBar.background": "#f2e8c6",
    "sideBarTitle.foreground": "#50493b",
    "list.activeSelectionForeground": "#4a4336",
    "list.activeSelectionBackground": "#ebddb4",
    "list.inactiveSelectionForeground": "#50493b",
    "list.inactiveSelectionBackground": "#ede0ba",
    "activityBar.foreground": "#50493b",
    "activityBar.background": "#f3eacc",
    "statusBar.foreground": "#4a4336",
    "statusBar.background": "#E4D4A6",
    "tab.activeForeground": "#4a4336",
    "tab.inactiveForeground": "#AA9B79",
    "titleBar.activeForeground": "#4a4336",
    "titleBar.inactiveForeground": "#AA9B79"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#a790c3"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#92af85"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#e5cec6"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#84aabe"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#58564d"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#d2a273"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#b2a4cf"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#adb5d7"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#bf98a1"
      }
    }
  ]
}
