{
  "name": "Soft Pastel Black Light",
  "colors": {
    "foreground": "#666c71",
    "editor.background": "#E7EBEF",
    "editor.foreground": "#666c71",
    "editor.selectionBackground": "#c6cfda",
    "editorCursor.foreground": "#8793a1",
    "editorLineNumber.foreground": "#adb2b6",
    "editorLineNumber.activeForeground": "#8c97a3",
    "editorIndentGuide.background1": "#dde1e5",
    "editorIndentGuide.activeBackground1": "#828c96",
    "editorWhitespace.foreground": "#dfe3e7",
    "editorInlayHint.foreground": "#9da6ad",
    "editorInlayHint.background": "#e0e5e9",
    "sideBar.foreground": "#666c71",
    "sideBar.background": "#dee3e8",
    "sideBarTitle.foreground": "#666c71",
    "list.activeSelectionForeground": "#5a5f63",
    "list.activeSelectionBackground": "#c6cfda",
    "list.inactiveSelectionForeground": "#666c71",
    "list.inactiveSelectionBackground": "#ccd4de",
    "activityBar.foreground": "#666c71",
    "activityBar.background": "#e1e6ea",
    "statusBar.foreground": "#5a5f63",
    "statusBar.background": "#CDD5DD",
    "tab.activeForeground": "#5a5f63",
    "tab.inactiveForeground": "#9da6ad",
    "titleBar.activeForeground": "#5a5f63",
    "titleBar.inactiveForeground": "#9da6ad"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#afbed1"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#a4bdac"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#d5cbd3"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#9bb6c9"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#6f7a82"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#d4b19e"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#b6afd2"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#b2bddb"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#c4aab6"
      }
    }
  ]
}
