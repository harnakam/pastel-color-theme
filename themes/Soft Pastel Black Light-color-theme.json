{
  "name": "Soft Pastel Black Light",
  "colors": {
    "foreground": "#40474D",
    "editor.background": "#E7EBEF",
    "editor.foreground": "#40474D",
    "editor.selectionBackground": "#c6cfda",
    "editorCursor.foreground": "#8793a1",
    "editorLineNumber.foreground": "#9ca1a6",
    "editorLineNumber.activeForeground": "#7d8894",
    "editorIndentGuide.background1": "#dadee2",
    "editorIndentGuide.activeBackground1": "#6d7883",
    "editorWhitespace.foreground": "#dde1e5",
    "editorInlayHint.foreground": "#8C969E",
    "editorInlayHint.background": "#e0e5e9",
    "sideBar.foreground": "#40474D",
    "sideBar.background": "#dee3e8",
    "sideBarTitle.foreground": "#40474D",
    "list.activeSelectionForeground": "#383e44",
    "list.activeSelectionBackground": "#c6cfda",
    "list.inactiveSelectionForeground": "#40474D",
    "list.inactiveSelectionBackground": "#ccd4de",
    "activityBar.foreground": "#40474D",
    "activityBar.background": "#e1e6ea",
    "statusBar.foreground": "#383e44",
    "statusBar.background": "#CDD5DD",
    "tab.activeForeground": "#383e44",
    "tab.inactiveForeground": "#8C969E",
    "titleBar.activeForeground": "#383e44",
    "titleBar.inactiveForeground": "#8C969E"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#a2b2c6"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#97b19e"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#d5cbd3"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#8da9bd"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#4c575f"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#caa38f"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#aaa1c7"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#a5b1d0"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#b89ca9"
      }
    }
  ]
}
