{
  "name": "Soft Pastel Black Light",
  "colors": {
    "foreground": "#3a4045",
    "editor.background": "#E7EBEF",
    "editor.foreground": "#3a4045",
    "editor.selectionBackground": "#c6cfda",
    "editorCursor.foreground": "#8793a1",
    "editorLineNumber.foreground": "#91969a",
    "editorLineNumber.activeForeground": "#838e9b",
    "editorIndentGuide.background1": "#d6dade",
    "editorIndentGuide.activeBackground1": "#707a85",
    "editorWhitespace.foreground": "#d9dde1",
    "editorInlayHint.foreground": "#8C969E",
    "editorInlayHint.background": "#e0e5e9",
    "sideBar.foreground": "#3a4045",
    "sideBar.background": "#dee3e8",
    "sideBarTitle.foreground": "#3a4045",
    "list.activeSelectionForeground": "#353b3f",
    "list.activeSelectionBackground": "#c6cfda",
    "list.inactiveSelectionForeground": "#3a4045",
    "list.inactiveSelectionBackground": "#ccd4de",
    "activityBar.foreground": "#3a4045",
    "activityBar.background": "#e1e6ea",
    "statusBar.foreground": "#353b3f",
    "statusBar.background": "#CDD5DD",
    "tab.activeForeground": "#353b3f",
    "tab.inactiveForeground": "#8C969E",
    "titleBar.activeForeground": "#353b3f",
    "titleBar.inactiveForeground": "#8C969E"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#9baabe"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#90a998"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#d5cbd3"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#87a2b5"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#454d54"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#c19c89"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#a39bbe"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#9ea9c8"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#b196a2"
      }
    }
  ]
}
