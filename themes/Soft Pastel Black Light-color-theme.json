{
  "name": "Soft Pastel Black Light",
  "colors": {
    "foreground": "#32373c",
    "editor.background": "#E7EBEF",
    "editor.foreground": "#32373c",
    "editor.selectionBackground": "#c6cfda",
    "editorCursor.foreground": "#8793a1",
    "editorLineNumber.foreground": "#7e8387",
    "editorLineNumber.activeForeground": "#8995a3",
    "editorIndentGuide.background1": "#ced2d6",
    "editorIndentGuide.activeBackground1": "#757f8b",
    "editorWhitespace.foreground": "#d1d5da",
    "editorInlayHint.foreground": "#7b848b",
    "editorInlayHint.background": "#e0e5e9",
    "sideBar.foreground": "#32373c",
    "sideBar.background": "#dee3e8",
    "sideBarTitle.foreground": "#32373c",
    "list.activeSelectionForeground": "#303439",
    "list.activeSelectionBackground": "#c6cfda",
    "list.inactiveSelectionForeground": "#32373c",
    "list.inactiveSelectionBackground": "#ccd4de",
    "activityBar.foreground": "#32373c",
    "activityBar.background": "#e1e6ea",
    "statusBar.foreground": "#303439",
    "statusBar.background": "#CDD5DD",
    "tab.activeForeground": "#303439",
    "tab.inactiveForeground": "#818a91",
    "titleBar.activeForeground": "#303439",
    "titleBar.inactiveForeground": "#818a91"
  },
  "tokenColors": [
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.separator.key-value",
        "punctuation.separator.key-value.properties"
      ],
      "settings": {
        "foreground": "#8e9bad"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.unquoted",
        "string.unquoted.properties",
        "meta.property-value",
        "meta.property-value.properties"
      ],
      "settings": {
        "foreground": "#849b8b"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line.number-sign",
        "comment.line.exclamation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#d5cbd3"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.property-list"
      ],
      "settings": {
        "foreground": "#7b94a5"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "support.variable",
        "variable.other.key",
        "variable.other.key.properties",
        "entity.other.attribute-name",
        "entity.other.attribute-name.properties"
      ],
      "settings": {
        "foreground": "#3a4147"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "number",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#b08f7d"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#958dae"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#909bb6"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "support.constant",
        "variable.other.constant",
        "constant.language.boolean",
        "constant.language.boolean.properties",
        "constant.character.escape",
        "constant.character.escape.properties"
      ],
      "settings": {
        "foreground": "#a18994"
      }
    }
  ]
}
